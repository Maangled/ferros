{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ferros.local/assets/loot/project.schema.json",
  "title": "FERROS Loot Project Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "kind",
    "role",
    "dims",
    "description",
    "notes",
    "renderFile",
    "components",
    "states"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "const": "project"
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "dims": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "defaultState": {
      "type": "string"
    },
    "renderFile": {
      "type": "string",
      "minLength": 1
    },
    "standaloneRenderFile": {
      "type": "string"
    },
    "legacyRenderFile": {
      "type": "string",
      "description": "Path to the pre-compositor monolithic render file, kept as fallback."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "groups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/group"
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/state"
      }
    }
  },
  "$defs": {
    "transform": {
      "type": "object",
      "description": "3D transform relative to parent. CSS px for translation, degrees for rotation. Rotation order: X → Y → Z.",
      "additionalProperties": false,
      "properties": {
        "tx": { "type": "number", "default": 0 },
        "ty": { "type": "number", "default": 0 },
        "tz": { "type": "number", "default": 0 },
        "rx": { "type": "number", "default": 0 },
        "ry": { "type": "number", "default": 0 },
        "rz": { "type": "number", "default": 0 },
        "scale": { "type": "number", "default": 1, "exclusiveMinimum": 0 }
      }
    },
    "pivot": {
      "type": "object",
      "description": "Transform-origin offset from the group's local origin. Defines the axis of rotation for articulated joints.",
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number", "default": 0 },
        "y": { "type": "number", "default": 0 },
        "z": { "type": "number", "default": 0 }
      }
    },
    "group": {
      "type": "object",
      "description": "Articulated group with its own transform, pivot, and state-driven transforms. Components reference groups by ID.",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "parent": {
          "type": ["string", "null"],
          "description": "ID of parent group, or null/omitted for root-level groups."
        },
        "transform": {
          "$ref": "#/$defs/transform"
        },
        "pivot": {
          "$ref": "#/$defs/pivot"
        },
        "stateTransforms": {
          "type": "object",
          "description": "Map of state label → transform override applied to this group when that state is active.",
          "additionalProperties": {
            "$ref": "#/$defs/transform"
          }
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "file",
        "role",
        "slot"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "slot": {
          "type": "string",
          "minLength": 1
        },
        "group": {
          "type": "string",
          "description": "ID of the group this component belongs to. Omit for root-level (body) components."
        },
        "instanceOf": {
          "type": "string",
          "description": "ID of the base component this is a placed instance of. Enables geometry deduplication — the compositor loads geometry once and clones."
        },
        "transform": {
          "$ref": "#/$defs/transform"
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "payload"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "control",
            "pose"
          ],
          "properties": {
            "control": {
              "type": "string"
            },
            "pose": {
              "type": "string"
            },
            "rarity": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}