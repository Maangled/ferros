{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ferros.local/assets/loot/project.schema.json",
  "title": "FERROS Loot Project Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "kind",
    "role",
    "dims",
    "description",
    "notes",
    "renderFile",
    "components",
    "states"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "const": "project"
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "dims": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "defaultState": {
      "type": "string"
    },
    "renderFile": {
      "type": "string",
      "minLength": 1
    },
    "standaloneRenderFile": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/state"
      }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "file",
        "role",
        "slot"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "slot": {
          "type": "string",
          "minLength": 1
        },
        "instances": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "payload"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "control",
            "pose"
          ],
          "properties": {
            "control": {
              "type": "string"
            },
            "pose": {
              "type": "string"
            },
            "rarity": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}