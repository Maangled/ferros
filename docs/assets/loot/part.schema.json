{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ferros.local/assets/loot/part.schema.json",
  "title": "FERROS Loot Part Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "parts"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "parts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/part"
      }
    }
  },
  "$defs": {
    "part": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "name",
        "file",
        "dims",
        "role",
        "viewer",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "kind": {
          "const": "part"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "icon": {
          "type": "string"
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "dims": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "viewer": {
          "type": "string",
          "enum": ["arena"]
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
